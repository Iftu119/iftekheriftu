---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---
<BaseLayout title={post.data.title} description={post.data.description}>
  <article class="post-page">
    <header class="post-header">
      <div class="post-meta-top">
        <a href="/blog" class="back-link">← All Posts</a>
        <span class="post-lang">{post.data.lang === 'bn' ? 'বাংলা' : 'English'}</span>
      </div>
      <h1 class="post-title">{post.data.title}</h1>
      <p class="post-desc">{post.data.description}</p>
      <div class="post-meta-bottom">
        <time>
          {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        <div class="post-tags">
          {post.data.tags.map(tag => <span class="tag">{tag}</span>)}
        </div>
      </div>
    </header>
    <div class="post-body">
      <Content />
    </div>
    <footer class="post-footer">
      <a href="/blog" class="back-link">← Back to Blog</a>
    </footer>
  </article>
</BaseLayout>

<style>
.post-page { max-width: 720px; margin: 0 auto; padding: 5rem 2.5rem; }
.post-meta-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 2rem;
}
.back-link {
  font-size: 0.7rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--muted);
  text-decoration: none;
  transition: color 0.2s;
}
.back-link:hover { color: var(--accent); }
.post-lang {
  font-size: 0.65rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--accent);
  border: 1px solid var(--accent);
  padding: 0.15rem 0.5rem;
}
.post-title {
  font-family: var(--font-display);
  font-size: clamp(2rem, 5vw, 3.5rem);
  font-weight: 300;
  line-height: 1.1;
  letter-spacing: -0.02em;
  margin-bottom: 1rem;
}
.post-desc { font-size: 0.9rem; color: var(--muted); line-height: 1.7; margin-bottom: 1.5rem; }
.post-meta-bottom {
  display: flex;
  align-items: center;
  gap: 1.5rem;
  padding-bottom: 2.5rem;
  border-bottom: 1px solid var(--border);
  margin-bottom: 3rem;
}
.post-meta-bottom time { font-size: 0.7rem; color: var(--muted); letter-spacing: 0.05em; }
.post-tags { display: flex; gap: 0.5rem; flex-wrap: wrap; }
.tag {
  font-size: 0.6rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--muted);
  border: 1px solid var(--border);
  padding: 0.15rem 0.5rem;
}

/* ── PROSE ── */
.post-body { font-size: 0.88rem; line-height: 1.9; color: #ccc8c0; }
.post-body :global(h2) {
  font-family: var(--font-display);
  font-size: 1.8rem;
  font-weight: 300;
  color: var(--text);
  margin: 2.5rem 0 1rem;
  letter-spacing: -0.01em;
}
.post-body :global(h3) {
  font-family: var(--font-display);
  font-size: 1.3rem;
  font-weight: 400;
  color: var(--text);
  margin: 2rem 0 0.75rem;
}
.post-body :global(p) { margin-bottom: 1.25rem; }
.post-body :global(a) { color: var(--accent); text-underline-offset: 3px; }
.post-body :global(ol), .post-body :global(ul) {
  margin: 1rem 0 1.25rem 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
}
.post-body :global(blockquote) {
  border-left: 2px solid var(--accent);
  padding-left: 1.25rem;
  margin: 1.5rem 0;
  color: var(--muted);
  font-style: italic;
}
.post-body :global(code) {
  background: var(--bg3);
  padding: 0.1rem 0.4rem;
  font-size: 0.8rem;
  color: var(--accent);
}
.post-body :global(pre) {
  background: var(--bg3);
  border: 1px solid var(--border);
  padding: 1.25rem;
  overflow-x: auto;
  margin: 1.5rem 0;
}
.post-footer { margin-top: 4rem; padding-top: 2rem; border-top: 1px solid var(--border); }

@media (max-width: 768px) {
  .post-page { padding: 4rem 1.5rem; }
}
</style>
