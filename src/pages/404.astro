---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="404 — Not Found">
  <div class="not-found">
    <span class="num">404</span>
    <h1>Page not found.</h1>
    <a href="/">← Go home</a>
  </div>
</BaseLayout>
<style>
.not-found {
  min-height: 80svh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  gap: 1rem;
  text-align: center;
  padding: 2rem;
}
.num {
  font-family: var(--font-display);
  font-size: 10rem;
  font-weight: 300;
  color: var(--bg3);
  line-height: 1;
}
h1 { font-family: var(--font-display); font-size: 2rem; font-weight: 300; }
a { font-size: 0.75rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); text-decoration: none; }
a:hover { color: var(--accent); }
</style>
